# Base URL of the ep-api instance, including the `/api` prefix.
# Matches the convention used by chm-website, ep-deaisummit2026, etc.
NEXT_PUBLIC_GCONF_API_URL=https://api.gconf.ai/api

# Tenant API key for gconf.ai — resolves the tenant automatically on the server.
# Get it from ep-dashboard → Platform → Tenants → view tenant → API Key card.
NEXT_PUBLIC_GCONF_API_KEY=
